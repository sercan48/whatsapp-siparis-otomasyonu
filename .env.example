# =====================================================
# ENVIRONMENT VARIABLES - ÖRNEK DOSYA
# =====================================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# .env dosyası ASLA Git'e commit edilmemelidir!
# =====================================================

# OpenAI API Key (Supabase Edge Functions'ta secret olarak saklanmalı)
# OPENAI_API_KEY=sk-proj-xxx

# Not: Tüm API key'leri Supabase Dashboard → Edge Functions → Secrets
# bölümünden yönetin. Local .env dosyası sadece development için kullanılabilir.

# Supabase (Frontend için - bunlar public key'ler)
# VITE_SUPABASE_URL=https://xxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJxxx

# =====================================================
# GÜVENLİK UYARISI
# =====================================================
# - Gerçek API key'leri ASLA bu dosyaya yazmayın
# - .env dosyası .gitignore'da olmalıdır
# - Production'da environment variables kullanın
# =====================================================
