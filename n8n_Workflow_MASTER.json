{
    "name": "WhatsApp MASTER (Verify + AI)",
    "active": true,
    "nodes": [
        {
            "parameters": {
                "httpMethod": "GET",
                "path": "webhook",
                "options": {}
            },
            "name": "Webhook (GET - Verify)",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                100,
                100
            ],
            "webhookId": "webhook"
        },
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "webhook",
                "options": {}
            },
            "name": "Webhook (POST - Messages)",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                100,
                400
            ],
            "webhookId": "webhook"
        },
        {
            "parameters": {
                "jsCode": "// Verify Token Logic\nconst query = items[0].json.query;\nconst challenge = query['hub.challenge'];\nconst token = query['hub.verify_token'];\nconst mySecret = 'whatsapp-demo-token';\n\nif (token === mySecret) {\n  return [{ json: { body: parseInt(challenge) } }];\n} else {\n  throw new Error('Invalid Token');\n}"
            },
            "name": "Check Verify Token",
            "type": "n8n-nodes-base.code",
            "typeVersion": 1,
            "position": [
                300,
                100
            ]
        },
        {
            "parameters": {
                "respondWith": "text",
                "responseBody": "={{ $json.body }}",
                "options": {}
            },
            "name": "Respond Challenge",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                500,
                100
            ]
        },
        {
